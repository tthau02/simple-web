# Copy to .env next to docker-compose.yml
# SQL Server password (complexity required by the image)
MSSQL_SA_PASSWORD=Change_me1!

# Browser calls API at this URL (baked into Next.js at build time)
NEXT_PUBLIC_API_URL=http://localhost:8080

# CORS: origin of the web app as seen by the browser
PUBLIC_WEB_ORIGIN=http://localhost:3000
